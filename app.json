{
  "expo": {
    "name": "브레이크포인트",
    "slug": "brakepoint",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "kr.co.cruxdata.brakepoint",
      "adaptiveIcon": {
        "backgroundColor": "#16181d",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "USE_FULL_SCREEN_INTENT",
        "WAKE_LOCK",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.health.READ_WEIGHT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": false
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "다음날 일정을 확인해 음주 페이스를 조절하는 데 사용해요."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "술자리 장소를 자동으로 입력하는 데 사용해요."
        }
      ],
      "./plugins/withFullScreenIntent",
      "./plugins/withHealthConnectDelegate",
      "./plugins/withHealthConnectActivity",
      "./plugins/withAndroidQueries",
      "expo-font",
      "react-native-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8c663838-b5f8-4c35-8aed-a89e78b70e1f"
      }
    },
    "owner": "jiny.king",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8c663838-b5f8-4c35-8aed-a89e78b70e1f",
      "requestHeaders": {
        "expo-channel-name": "preview"
      }
    }
  }
}
